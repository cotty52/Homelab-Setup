# =============================================================================
# ~/homelab/.env — Environment variables for docker-compose.yml
# =============================================================================
# Edit these paths before running: docker compose up -d
# Lines starting with # are comments and are ignored.

# Path to your media folder (movies, TV shows, music, etc.)
# This gets mounted into Jellyfin (and Sonarr/Radarr if you enable them).
MEDIA_PATH=/path/to/your/media

# Path to your downloads folder (only needed if you enable qBittorrent/arr stack)
# DOWNLOADS_PATH=/path/to/your/downloads
